# Agent endpoint (set this to your deployed URL)
AGENT_BASE_URL=https://your-agent-endpoint.example.com

# Clay API key (for writing flags back to Clay rows)
CLAY_API_KEY=your_clay_api_key_here

# Email service (Mailjet)
MAILEJET_API_KEY=your_mailjet_api_key_here
MAILEJET_API_SECRET=your_mailjet_api_secret_here
REVIEW_EMAIL_FROM=no-reply@yourdomain.com
REVIEW_EMAIL_FROM_NAME=GTM Enrichment Agent
REVIEW_EMAIL_TO=you@yourdomain.com

# Review UI base URL (for approve links in batch email)
REVIEW_UI_BASE_URL=https://your-review-ui.example.com

# DuckDB file path
DUCKDB_PATH=./data/static_data.duckdb

# DOL Form 5500 source data (parquet or CSV)
DOL_DATA_PATH=./data/dol_form5500.parquet

# NAICS source data
NAICS_DATA_PATH=./data/naics_codes.csv

# Confidence thresholds
CONFIDENCE_AUTO_WRITE=0.80
CONFIDENCE_REVIEW_LOW=0.60

# Review batch expiry (days)
REVIEW_BATCH_EXPIRY_DAYS=7
